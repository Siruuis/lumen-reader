{
  "name": "cozy-reader",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "description": "Lumen — a cozy, eye-friendly desktop reader for long PDFs, EPUBs and online articles.",
  "author": "Siruuis",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c green,cyan \"vite\" \"wait-on tcp:127.0.0.1:5180 && cross-env ELECTRON_DEV=1 electron .\"",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "pack": "vite build && electron-packager . Lumen --platform=win32 --arch=x64 --out=release --overwrite --icon=build/icon.ico --app-version=1.0.0 --ignore=node_modules --ignore=/src --ignore=/release --ignore=/build",
    "dist": "vite build && electron-builder",
    "release": "npm version patch && git push --follow-tags"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "electron-updater": "^6.3.9",
    "epubjs": "^0.3.93",
    "idb-keyval": "^6.2.1",
    "pdfjs-dist": "^4.7.76",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "js-yaml": "^4.1.0",
    "playwright": "^1.61.1",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.lumen.reader",
    "productName": "Lumen",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Siruuis",
        "repo": "lumen-reader",
        "releaseType": "release"
      }
    ]
  }
}
